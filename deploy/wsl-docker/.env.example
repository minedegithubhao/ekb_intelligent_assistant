TZ=Asia/Shanghai

# In mainland China, these mirror-prefixed images are often more reliable.
# For production with direct registry access, switch to official image refs:
# MYSQL_IMAGE=mysql:8.4
# REDIS_IMAGE=redis:7.4
# MILVUS_IMAGE=milvusdb/milvus:v2.5.18
# MINIO_IMAGE=minio/minio:RELEASE.2024-12-18T13-15-44Z
MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.4
REDIS_IMAGE=docker.m.daocloud.io/library/redis:7.4
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.18
MINIO_IMAGE=docker.m.daocloud.io/minio/minio:RELEASE.2024-12-18T13-15-44Z
MILVUS_IMAGE=docker.m.daocloud.io/milvusdb/milvus:v2.5.18

MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=replace_with_strong_mysql_root_password
MYSQL_DATABASE=knowforge_rag
MYSQL_USER=knowforge
MYSQL_PASSWORD=replace_with_strong_mysql_password

REDIS_PORT=6379
REDIS_PASSWORD=replace_with_strong_redis_password

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=knowforge_minio
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password

MILVUS_PORT=19530
MILVUS_WEB_PORT=9091
