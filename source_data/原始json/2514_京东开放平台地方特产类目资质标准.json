    "title": "京东开放平台地方特产类目资质标准",
    "summary": "京东开放平台地方特产类目资质标准",
    "created": "2018-12-05",
    "modified": "2024-09-04",
    "url": "https://rule.jd.com/rule/ruleDetail.action?ruleId=2514&type=0&btype=1"
