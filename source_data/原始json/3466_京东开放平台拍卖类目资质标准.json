    "content": "<table class=\"MsoNormalTable\" style=\"border-collapse: collapse; width: 100%; background-color: white;\" border=\"0\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\">\n<tbody>\n<tr style=\"height: 17.5pt;\">\n<td style=\"width: 56.2pt; border: solid windowtext 1.0pt; background: #C00000; padding: 0cm 5.4pt 0cm 5.4pt; height: 17.5pt;\" width=\"75\">\n<p style=\"text-align: center; line-height: 2; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"center\"><span style=\"font-size: 10pt;\"><strong><span style=\"font-family: 微软雅黑, sans-serif; color: white;\">一级类目</span></strong></span></p>\n</td>\n<td style=\"width: 63.8pt; border-top: 1pt solid windowtext; border-right: 1pt solid windowtext; border-bottom: 1pt solid windowtext; border-image: initial; border-left: none; background: #c00000; padding: 0cm 5.4pt; height: 17.5pt; line-height: 2;\" width=\"85\">\n<p style=\"text-align: center; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"center\"><span style=\"font-size: 10pt;\"><strong><span style=\"font-family: 微软雅黑, sans-serif; color: white;\">二级类目/商家类型</span></strong></span></p>\n</td>\n<td style=\"width: 70.9pt; border-top: 1pt solid windowtext; border-right: 1pt solid windowtext; border-bottom: 1pt solid windowtext; border-image: initial; border-left: none; background: #c00000; padding: 0cm 5.4pt; height: 17.5pt; line-height: 2;\" width=\"95\">\n<p style=\"text-align: center; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"center\"><span style=\"font-size: 10pt;\"><strong><span style=\"font-family: 微软雅黑, sans-serif; color: white; background: #be1a1d;\">三级类目</span></strong></span></p>\n</td>\n<td style=\"width: 49.6pt; border-top: 1pt solid windowtext; border-right: 1pt solid windowtext; border-bottom: 1pt solid windowtext; border-image: initial; border-left: none; background: #c00000; padding: 0cm; height: 17.5pt; line-height: 2;\" width=\"66\">\n<p style=\"text-align: center; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"center\"><span style=\"font-size: 10pt;\"><strong><span style=\"font-family: 微软雅黑, sans-serif; color: white; background: #be1a1d;\">行业资质</span></strong></span></p>\n</td>\n<td style=\"width: 233.9pt; border-top: 1pt solid windowtext; border-right: 1pt solid windowtext; border-bottom: 1pt solid windowtext; border-image: initial; border-left: none; background: #c00000; padding: 0cm; height: 17.5pt; line-height: 2;\" width=\"312\">\n<p style=\"text-align: center; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"center\"><span style=\"font-size: 10pt;\"><strong><span style=\"font-family: 微软雅黑, sans-serif; color: white;\">特殊资质及要求</span></strong></span></p>\n</td>\n</tr>\n<tr style=\"height: 14.5pt;\">\n<td style=\"width: 56.2pt; border: solid windowtext 1.0pt; border-top: none; padding: 0cm 0cm 0cm 0cm; height: 14.5pt;\" rowspan=\"7\" width=\"75\">\n<p style=\"margin: 0cm; font-size: 10.5pt; font-family: 等线; text-align: center;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black;\">拍卖</span></p>\n</td>\n<td style=\"width: 63.8pt; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; padding: 0cm 5.4pt 0cm 5.4pt; height: 14.5pt;\" nowrap=\"nowrap\" width=\"85\">\n<p style=\"text-align: center; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"center\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black;\">资产</span></p>\n</td>\n<td style=\"width: 70.9pt; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; background: transparent; padding: 0cm 5.4pt 0cm 5.4pt; height: 14.5pt;\" width=\"95\">\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; background: white;\">股权，其他用房，机动车，库存物资，租赁/经营权，商业用房，招标采购，其他资产，土地，机械设备，知识产权，无形资产，资产拍卖线下服务，债权，林权，其他交通运输工具，船舶，住宅用房，工业用房</span></p>\n</td>\n<td style=\"width: 49.6pt; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; background: transparent; padding: 0cm 0cm 0cm 0cm; height: 14.5pt;\" width=\"66\">\n<p style=\"text-align: center; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"center\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; background: white;\">/</span></p>\n</td>\n<td style=\"width: 233.9pt; border-top: none; border-left: none; border-bottom: solid windowtext 1.0pt; border-right: solid windowtext 1.0pt; background: transparent; padding: 0cm 0cm 0cm 0cm; height: 14.5pt;\" width=\"312\">\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10pt;\"><span style=\"font-family: 微软雅黑, sans-serif;\">&nbsp;<span style=\"color: black; background: white;\">1.</span></span><span style=\"font-family: 微软雅黑, sans-serif; color: black; background: white;\">定向经营类目，在新增经营类目时需经审核后方可运营。</span></span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10pt;\"><span style=\"font-family: 微软雅黑, sans-serif; color: black; background: white;\">2.</span><span style=\"font-family: 微软雅黑, sans-serif; color: black; background: white;\">合作对象</span></span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; background: white;\">政府机关、金融机构、资产管理公司、交易所（包括但不限于金融资产交易所、产权交易所、商品交易所等）、拍卖行等。</span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10pt;\"><span style=\"font-family: 微软雅黑, sans-serif; color: black; background: white;\">3.&nbsp;</span><span style=\"font-family: 微软雅黑, sans-serif; color: black; background: white;\">入驻开店条件（公司性质的合作对象）</span></span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; background: white;\">① 注册资金500万元人民币以上。</span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; background: white;\">② 成立年限须满足一年以上。</span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; background: white;\">③ 拍卖经营批准证书（拍卖公司或营业范围中包含&ldquo;拍卖&rdquo;的非拍卖公司需提供）。</span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10pt;\"><span style=\"font-family: 微软雅黑, sans-serif; color: black; background: white;\">4.&nbsp;</span><span style=\"font-family: 微软雅黑, sans-serif; color: black; background: white;\">相关材料</span></span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; background: white;\">① 公司介绍材料。</span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; background: white;\">② 五个以上行业相关成交案例。</span></p>\n<p style=\"text-align: left; line-height: 21pt; margin: 0cm; font-size: 10.5pt; font-family: 等线;\" align=\"left\"><span style=\"font-size: 10.0pt; font-family: 微软雅黑, sans-serif; color: black; backgroun