span style=\"font-size: 10.0pt; line-height: 115%; font-family: 微软雅黑, sans-serif;\">2%</span></p>\n</td>\n<td style=\"width: 72.0pt; padding: .75pt .75pt .75pt .75pt;\" width=\"96\">\n<p style=\"margin: 0cm 0cm 8pt; line-height: 115%; font-size: 11pt; font-family: 等线;\"><span style=\"font-size: 10.0pt; line-height: 115%; font-family: 微软雅黑, sans-serif;\">8%</span></p>\n</td>\n<td style=\"width: 69.75pt; padding: .75pt .75pt .75pt .75pt;\" width=\"93\">\n<p style=\"margin: 0cm 0cm 8pt; line-height: 115%; font-size: 11pt; font-family: 等线;\"><span style=\"font-size: 10.0pt; line-height: 115%; font-family: 微软雅黑, sans-serif;\">8%</span></p>\n</td>\n<td style=\"width: 88.5pt; padding: .75pt .75pt .75pt .75pt;\" rowspan=\"11\" width=\"118\">\n<p style=\"margin: 0cm 0cm 8pt; line-height: 115%; font-size: 11pt; font-family: 等线;\"><span style=\"font-size: 10.0pt; line-height: 115%; font-family: 微软雅黑, sans-serif;\">15</span><span style=\"font-size: 10.0pt; line-height: 115%; font-family: 微软雅黑, sans-serif;\">万</span></p>\n</td>\n</tr>\n<tr>\n<td style=\"width: 90.0pt; padding: .75pt .75pt .75pt .75pt;\" width=\"120\">\n<p style=\"margin: 0cm 0cm 8pt; line-height: 115%; font-size: 11pt; font-family: 等线;\"><span style=\"font-size: 10.0pt; line-height: 115%; font-family: 微软雅黑, sans-serif;\">智能眼镜</span></p>\n</td>\n<td style=\"width: 87.75pt; padding: .75pt .75pt .75pt .75pt;\" width=\"117\">\n<p style=\"margin: 0cm 0cm 8pt; line-height: 115%; font-size: 11pt; font-family: 等线;\"><span style=\"font-size: 10.0pt; line-height: 115%; font-family: 微软雅黑, sans-serif;\">15</span><span style=\"font-size: 10.0pt; line-height: 115%; font-family: 微软雅黑, sans-serif;\">万</span></p>\n</td>\n<td style=\"width: 75.75pt; padding: .75pt .75pt .75pt .75pt;\" width=\"101\">&nbsp;</td>\n<td style=\"width: 72.0pt; padding: .75pt .75pt .75pt .75pt;\" rowspan=\"4\" width=\"96\">\n<p style=\"margin: 0cm 0cm 8pt; line-height: 115%; font-size: 11pt; font-family: 等线;\"><span style=\"font-size: 10.0pt; line-heigh